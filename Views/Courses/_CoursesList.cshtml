@model IEnumerable<PFI.Models.Course>

@foreach (int session in Model.Select(c => c.Session).Distinct().OrderBy(s => s))
{
    var courses = Model.Where(c => c.Session == session).OrderBy(c => c.Code).ToList();
    <details id="details_session_@session" open>
        <summary>Session @session</summary>
        <div>
            @foreach (var course in courses)
            {
                <div class="CoursesListLayout">
                    <a href="@Url.Action("Details","Courses", new { id = course.Id })">
                        <span class="courseCode">@course.Code</span>
                        @course.Title
                    </a>
                </div>
            }
        </div>
    </details>
}
