@model PFI.Models.Teacher
@using System.Globalization
@{
    var yearsList = Model.Allocations.Select(a => a.Year).Distinct().OrderByDescending(y => y).ToList();
    var seniority = DateTime.Now.Year - Model.StartDate.Year;
    if (Model.StartDate > DateTime.Now.AddYears(-seniority))
    {
        seniority--;
    }
}

<details id="details_teacher_@Model.Id" open>
    <summary><i class="fa fa-id-card"></i> @Model.LastName @Model.FirstName</summary>
    <div style="padding-left:12px;">
        <div style="margin-bottom:4px;"><i class="fa fa-barcode"></i> <span style="color:black;font-family:Consolas;">@Model.Code</span></div>
        <div style="margin-bottom:4px;"><i class="fa fa-phone"></i> @Model.Phone</div>
        @if (!string.IsNullOrEmpty(Model.Email))
        {
            <div style="margin-bottom:4px;"><i class="fa fa-paper-plane"></i> @Model.Email</div>
        }
        <div style="margin-bottom:4px;">Embauche le @Model.StartDate.ToString("d MMMM yyyy", new CultureInfo("fr-CA"))</div>
        <div style="margin-bottom:4px;">@seniority.ToString("F1", CultureInfo.InvariantCulture) ans d'anciennete</div>
        @if (!string.IsNullOrEmpty(Model.Avatar))
        {
            <img src="@Model.Avatar" class="teacherDetailsAvatar" />
        }
    </div>
</details>

<details id="details_allocations" open>
    <summary>Allocations</summary>
    <div>
        @foreach (int year in yearsList)
        {
            var allocations = Model.Allocations.Where(a => a.Year == year).OrderBy(a => a.Course.Code).ToList();
            <details id="details_alloc_@year" open>
                <summary>@year</summary>
                <div style="padding-left:12px;">
                    @foreach (var alloc in allocations)
                    {
                        <div style="padding:2px 0;">
                            <a href="@Url.Action("Details","Courses", new { id = alloc.CourseId })" style="text-decoration:none;color:black;">
                                <span style="color:gray;font-family:Consolas;">[@alloc.Id]</span> <span style="color:#0000FF;font-family:Consolas;">@alloc.Course.Code</span> @alloc.Course.Title
                            </a>
                        </div>
                    }
                </div>
            </details>
        }
        @if (yearsList.Count == 0)
        {
            <div style="color:gray;padding-left:12px;">Aucune allocation</div>
        }
    </div>
</details>
