@* Vue pour voir un etudiant *@
@model PFI.Models.Student
@{
    ViewBag.Title = "Etudiant - Details";
    var yearsList = Model.Registrations.Select(r => r.Year).Distinct().OrderByDescending(y => y).ToList();
    bool canWrite = Session["access"] != null && (PFI.Models.Access)Session["access"] >= PFI.Models.Access.ReadWrite;
}

<div class="appHeader">
    <img src="~/App_Assets/lionelg.png" class="logo" />
    <div class="navTabs">
        <span style="font-weight:bold;">Etudiant - Details</span>
    </div>
    <div class="headerActions">
        @if (canWrite)
        {
            <a href="@Url.Action("Edit","Students", new { id = Model.Id })" title="Modifier">
                <i class="fa fa-pen-to-square fa-xl" style="color:#0057CC;"></i>
            </a>
            <span style="cursor:pointer;" title="Supprimer"
                  onclick="bootbox.confirm({
                    closeButton: false,
                    message: '<span style=\'color:red;font-weight:bold;\'>Effacer ?</span>',
                    buttons: {
                        cancel: { label: 'Annuler', className: 'btn-secondary' },
                        confirm: { label: 'D\'accord', className: 'btn-primary' }
                    },
                    callback: function(result) {
                        if (result) {
                            document.getElementById('deleteForm_@Model.Id').submit();
                        }
                    }
                  })">
            <i class="fa fa-trash-can fa-xl" style="color:#0057CC;"></i>
            </span>
            using (Html.BeginForm("Delete", "Students", new { id = Model.Id }, FormMethod.Post, new { id = "deleteForm_" + Model.Id }))
            {
            }
        }
        <a href="@Url.Action("Index","Students")" title="Retour">
            <i class="fa fa-square-xmark fa-xl" style="color:#0057CC;"></i>
        </a>
    </div>
</div>

<div class="pageContent">
    <details id="details_student_@Model.Id" open>
        <summary><i class="fa fa-graduation-cap"></i> @Model.LastName @Model.FirstName</summary>
        <div>
            <p><i class="fa fa-barcode"></i> @Model.Code</p>
            <p><i class="fa fa-phone"></i> @Model.Phone</p>
            <p><i class="fa fa-paper-plane"></i> @Model.Email</p>
            <p><i class="fa fa-cake-candles"></i> @Model.BirthDate.ToString("dd MMMM yyyy", new System.Globalization.CultureInfo("fr-CA"))</p>
        </div>
    </details>

    <div class="inscriptions-section" style="margin-top:12px;">
        <h2 style="font-size:1.2rem;font-weight:bold;border-top:1px solid #ddd;padding-top:8px;margin-bottom:8px;">Inscriptions</h2>
        @if (yearsList.Any())
        {
            foreach (int year in yearsList)
            {
                var registrations = Model.Registrations.Where(r => r.Year == year).OrderBy(r => r.Course.Session).ToList();
                <details id="details_reg_@year" open>
                    <summary>@year</summary>
                    <div>
                        @foreach (var reg in registrations)
                        {
                            <div class="CoursesListLayout">
                                <a href="@Url.Action("Details","Courses", new { id = reg.CourseId })">
                                    [@reg.Course.Session] <span class="courseCode">@reg.Course.Code</span> @reg.Course.Title
                                </a>
                            </div>
                        }
                    </div>
                </details>
            }
        }
    </div>
</div>

@section scripts {
    <script>
        RestoreDetailsState();
        setInterval(function () {
            $.get('@Url.Action("Details", "Students", new { id = Model.Id })', function (data) {
                var doc = new DOMParser().parseFromString(data, 'text/html');
                $('.pageContent').html($(doc).find('.pageContent').html());
                RestoreDetailsState();
            });
        }, 5000);
    </script>
}